<Window x:Class="bismuthIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Bismuth IDE" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="150"/>  </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Run" Click="RunButton_Click"/>
            </MenuItem>
        </Menu>

        <avalonEdit:TextEditor Grid.Row="1"
                               Name="CodeEditor"
                               FontFamily="Consolas"
                               FontSize="14pt"
                               ShowLineNumbers="True"/>
                               
        <TextBox Grid.Row="2" Name="OutputLog" IsReadOnly="True" Background="#f0f0f0"/>
    </Grid>
</Window>